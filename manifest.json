{
    "manifest_version": 3,
    "name": "Gmail Opener",
    "description": "A simple Chrome extension to open Gmail directly.",
    "version": "2.0.0",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "https://accounts.google.com/*",
        "https://mail.google.com/*"
    ],
    "action": {
        "default_icon": "icon.png"
    },
    "options_page": "options.html",
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "popup.html",
                "popup.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "https://accounts.google.com/*",
                "https://mail.google.com/*"
            ],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "48": "icon.png"
    }
}